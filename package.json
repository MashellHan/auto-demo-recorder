{
  "name": "auto-demo-recorder",
  "version": "0.1.0",
  "description": "On-demand terminal demo recording + AI annotation CLI tool",
  "type": "module",
  "bin": {
    "demo-recorder": "./dist/bin/demo-recorder.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/demo-recorder.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ bin/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["demo", "recording", "terminal", "tui", "vhs", "annotation", "cli"],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
